# ================================
# Configuração para Keycloak + Loto
# ================================

# Crie um arquivo .env na raiz do projeto com estas variaveis

# -------- Keycloak --------
# URL do servidor Keycloak
KEYCLOAK_SERVER_URL=http://localhost:8080

# Nome do realm (tenant) no Keycloak
KEYCLOAK_REALM=loto-realm

# ID do cliente registrado no Keycloak
KEYCLOAK_CLIENT_ID=loto-app

# Secret do cliente (obter em Keycloak Admin Console → Credentials)
KEYCLOAK_CLIENT_SECRET=seu-secret-aqui-mudar-em-producao

# URL de redirect após login (deve estar configurada no cliente Keycloak)
KEYCLOAK_REDIRECT_URI=http://localhost:5000/auth/callback

# URL de redirect após logout
KEYCLOAK_LOGOUT_REDIRECT_URI=http://localhost:5000

# -------- Autenticação --------
# Modo de autenticação: 'keycloak' ou 'local'
AUTH_MODE=keycloak

# Chave secreta do Flask (alterar para valor aleatório em produção)
FLASK_SECRET_KEY=seu-secret-key-aleatorio-aqui-mudar-em-producao

# -------- Tokens --------
# Tempo de expiração do access token (segundos)
TOKEN_EXPIRY=3600

# Tempo de expiração do refresh token (segundos)
REFRESH_TOKEN_EXPIRY=86400

# -------- Banco de Dados (Keycloak) --------
# Usuário do PostgreSQL para Keycloak
POSTGRES_USER=keycloak

# Senha do PostgreSQL para Keycloak
POSTGRES_PASSWORD=keycloak_password_change_me

# Nome do banco de dados
POSTGRES_DB=keycloak

# -------- Admin Keycloak --------
# Usuário admin do Keycloak
KEYCLOAK_ADMIN=admin

# Senha admin do Keycloak
KEYCLOAK_ADMIN_PASSWORD=admin_password_change_me

# ================================
# INSTRUÇÕES DE USO
# ================================
# 1. Copie este arquivo para .env
# 2. Altere os valores conforme sua configuração
# 3. Para produção, use valores seguros e aleatórios para:
#    - KEYCLOAK_CLIENT_SECRET
#    - FLASK_SECRET_KEY
#    - KEYCLOAK_ADMIN_PASSWORD
#    - POSTGRES_PASSWORD
# 4. Certifique-se de que KEYCLOAK_REDIRECT_URI corresponde
#    ao "Valid redirect URI" configurado no cliente Keycloak
